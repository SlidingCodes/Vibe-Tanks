{$DOMAIN:localhost} {
	root * /srv
	encode zstd gzip

	route {
		reverse_proxy /socket.io* server:3001
		reverse_proxy /healthz server:3001
		try_files {path} /index.html
		file_server
	}
}

# Admin dashboard on its own subdomain. Caddy auto-provisions the TLS
# cert when DNS for `admin.<your-domain>` points at this host. The
# dashboard runs as an isolated Node process on admin:3002 and talks
# to the game server's loopback control plane on its own — the game
# never serves admin traffic itself.
admin.{$DOMAIN:localhost} {
	encode zstd gzip
	reverse_proxy admin:3002
}
